{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(login|signup|dashboard|qr|settings|unlock|analytics|stats)",
      "destination": "/index.html"
    },
    {
      "source": "/(login|signup|dashboard|qr|settings|unlock|analytics|stats)/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/([^/\\.]+)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
